# Random server-only string used to hash viewer IPs for share-view analytics.
# Daily-rotated: dailySalt = sha256(IP_HASH_BASE_SALT + YYYY-MM-DD).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
IP_HASH_BASE_SALT=

# Enable Banking sandbox (AIS demo at /demo/open-banking).
# Generate the keypair in the EB control panel and paste the PEM-encoded
# private key here; newlines must be escaped as \n in .env.local.
EB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
EB_APP_ID="your-app-id-from-enablebanking-portal"
