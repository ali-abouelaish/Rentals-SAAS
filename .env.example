# Random server-only string used to hash viewer IPs for share-view analytics.
# Daily-rotated: dailySalt = sha256(IP_HASH_BASE_SALT + YYYY-MM-DD).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
IP_HASH_BASE_SALT=

# Enable Banking sandbox (AIS demo at /demo/open-banking).
# Generate the keypair in the EB control panel and paste the PEM-encoded
# private key here; newlines must be escaped as \n in .env.local.
EB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
EB_APP_ID="your-app-id-from-enablebanking-portal"

# TDS (Tenancy Deposit Scheme) deposit integration.
# 32-byte hex key (64 hex chars) used to encrypt each agency's TDS api_key at
# rest. Generate with: openssl rand -hex 32
# NOTE: the actual TDS credentials (Member ID, Branch ID, API Key) are NOT env
# vars — a super admin enters them per agency under /admin/deposit-schemes and
# they are stored encrypted in the tds_connections table.
TDS_TOKEN_SECRET=

# DPS (Deposit Protection Service / Computershare) deposit integration.
# 32-byte hex key (64 hex chars) used to encrypt each agency's DPS client_secret
# at rest. Generate with: openssl rand -hex 32
# NOTE: the actual DPS credentials (Client ID, Client Secret, Agent/Landlord ID)
# are NOT env vars — a super admin enters them per agency under
# /admin/deposit-schemes and they are stored encrypted in dps_connections.
# (DPS_TEST_* vars are only read by scripts/dps-uat-probe.mjs, not the app.)
DPS_TOKEN_SECRET=

# mydeposits (Total Property) auth flow selector.
#   browser  = default; authorization-code redirect via /connect/authorize.
#   headless = email/SMS "Login" (Consumer) flow via /api/v1/ui/* — fallback
#              while the browser authorize endpoint returns a blank page.
# Probe the headless flow before switching: npm run mydeposits:headless
MYDEPOSITS_AUTH_MODE=browser

# OPTIONAL — Supabase JWT secret for opt-in app-layer access-token signature
# verification (defense-in-depth on top of RLS). When set, the server verifies
# each access token's HS256 signature before trusting its `sub`/`exp`; when
# unset, the token is decoded without a signature check (RLS remains the DB
# boundary). Value = Supabase dashboard → Settings → API → JWT Secret.
# ONLY set this for projects using the legacy symmetric (HS256) JWT secret.
# Projects on Supabase's asymmetric JWT signing keys (ES256/RS256) must leave
# this UNSET, or every session will fail verification.
SUPABASE_JWT_SECRET=

# OPTIONAL — extra webhook auth. The Gmail push webhook prefers a secret sent
# via the `x-webhook-secret` (or `Authorization: Bearer`) header, falling back
# to the `?secret=` query param for Google Pub/Sub (which can't send headers).
GMAIL_WEBHOOK_SECRET=
